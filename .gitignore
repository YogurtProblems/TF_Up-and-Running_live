# Terraform working directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Sensitive variable files
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config files
.terraformrc
terraform.rc

# OS/editor junk
.DS_Store
Thumbs.db

# Sublime Text
*.sublime-workspace
*.sublime-project

# Python cache (sometimes appears with tooling)
__pycache__/
*.pyc